# =============================================================================
# ServiceFlow V2 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---
# PostgreSQL connection string (supports Supabase, Neon, or any Postgres host)
# For Supabase pooler: use the "Transaction" mode pooler URL
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The canonical URL of your deployed app (no trailing slash)
AUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
# Get your API key at https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"

# The "From" address for all outgoing emails (must be verified in Resend)
EMAIL_FROM="ServiceFlow <noreply@yourdomain.com>"

# --- App ---
# Public-facing base URL (used in email links, og:image, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
