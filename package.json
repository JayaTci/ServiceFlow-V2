{
  "name": "serviceflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "brace-expansion@5": "5.0.6",
      "esbuild": "0.28.0",
      "postcss": "8.5.15"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push --config ServiceFlow_v2Database/drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config ServiceFlow_v2Database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ServiceFlow_v2Database/drizzle.config.ts",
    "db:seed": "tsx ServiceFlow_v2Database/seeds/seed.ts",
    "db:bootstrap-users": "tsx ServiceFlow_v2Database/seeds/bootstrap-users.ts",
    "db:studio": "drizzle-kit studio --config ServiceFlow_v2Database/drizzle.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "shadcn": "4.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
